---
import BaseLayout from '../layouts/BaseLayout.astro'
---

<BaseLayout
  title="Home Emergency Preparedness Articles"
  description="Guides, tips, and research on protecting your home from natural disasters. Hurricanes, floods, wildfires, tornadoes, and winter storms."
>

  <section class="threat-hero">
    <div class="hero-img-wrap">
      <img src="https://images.unsplash.com/photo-1504711434969-e33886168f5c?w=1600&q=80&fit=crop" alt="Storm research" class="hero-img" />
      <div class="hero-overlay"></div>
    </div>
    <div class="container hero-content">
      <div class="hero-label">Articles & Guides</div>
      <h1>Home Emergency Preparedness Guides</h1>
      <p class="hero-sub">
        In-depth guides on protecting your home from every major natural disaster threat.
        Written for homeowners, not emergency managers.
      </p>
    </div>
  </section>

  <div class="container articles-layout">

    <h2 class="section-heading">Threat Guides</h2>
    <div class="article-grid">

      <a href="/hurricanes" class="article-card">
        <div class="article-img">
          <img src="https://images.unsplash.com/photo-1563089145-599997674d42?w=600&q=80&fit=crop" alt="Hurricane" />
        </div>
        <div class="article-body">
          <div class="article-tag">Hurricane</div>
          <h3>How to Protect Your Home from Hurricanes</h3>
          <p>Generators, flood insurance, storm shutters, yard prep, and emergency supplies — the complete guide.</p>
          <span class="article-link">Read Guide →</span>
        </div>
      </a>

      <a href="/flooding" class="article-card">
        <div class="article-img">
          <img src="https://images.unsplash.com/photo-1547683905-f686c993aae5?w=600&q=80&fit=crop" alt="Flooding" />
        </div>
        <div class="article-body">
          <div class="article-tag">Flooding</div>
          <h3>How to Protect Your Home from Flooding</h3>
          <p>Flood insurance, sump pumps, barriers, and interior protection. Including the 30-day insurance rule.</p>
          <span class="article-link">Read Guide →</span>
        </div>
      </a>

      <a href="/wildfires" class="article-card">
        <div class="article-img">
          <img src="https://images.unsplash.com/photo-1542401886-65d6c61db217?w=600&q=80&fit=crop" alt="Wildfire" />
        </div>
        <div class="article-body">
          <div class="article-tag">Wildfire</div>
          <h3>How to Protect Your Home from Wildfires</h3>
          <p>Defensible space, home hardening, evacuation planning, and air quality protection.</p>
          <span class="article-link">Read Guide →</span>
        </div>
      </a>

      <a href="/tornadoes" class="article-card">
        <div class="article-img">
          <img src="https://images.unsplash.com/photo-1558618666-fcd25c85cd64?w=600&q=80&fit=crop" alt="Tornado" />
        </div>
        <div class="article-body">
          <div class="article-tag">Tornado</div>
          <h3>How to Protect Your Family from Tornadoes</h3>
          <p>Shelter planning, safe rooms, warning systems, and what to do when sirens sound.</p>
          <span class="article-link">Read Guide →</span>
        </div>
      </a>

      <a href="/winter-storms" class="article-card">
        <div class="article-img">
          <img src="https://images.unsplash.com/photo-1511131341194-24e2eeeebb09?w=600&q=80&fit=crop" alt="Winter storm" />
        </div>
        <div class="article-body">
          <div class="article-tag">Winter Storm</div>
          <h3>How to Protect Your Home from Winter Storms</h3>
          <p>Frozen pipe prevention, heating backup, ice dams, and emergency supplies for extended outages.</p>
          <span class="article-link">Read Guide →</span>
        </div>
      </a>

    </div>

    <h2 class="section-heading">Product Guides</h2>
    <div class="article-grid">

      <a href="/generators" class="article-card">
        <div class="article-img">
          <img src="https://images.unsplash.com/photo-1621905251189-08b45d6a269e?w=600&q=80&fit=crop" alt="Generators" />
        </div>
        <div class="article-body">
          <div class="article-tag article-tag-product">Generators</div>
          <h3>Best Generators for Home Use — Buying Guide</h3>
          <p>Portable, inverter, dual fuel, and standby generators compared. Includes sizing calculator and top picks.</p>
          <span class="article-link">Read Guide →</span>
        </div>
      </a>

      <a href="/flood-protection-products" class="article-card">
        <div class="article-img">
          <img src="https://images.unsplash.com/photo-1504691342899-4d92b50853e1?w=600&q=80&fit=crop" alt="Flood protection" />
        </div>
        <div class="article-body">
          <div class="article-tag article-tag-product">Flood Products</div>
          <h3>Best Flood Protection Products for Homeowners</h3>
          <p>Barriers, sump pumps, backup systems, water alarms, and moisture control — by category.</p>
          <span class="article-link">Read Guide →</span>
        </div>
      </a>

      <a href="/emergency-kits" class="article-card">
        <div class="article-img">
          <img src="https://images.unsplash.com/photo-1584308666744-24d5c474f2ae?w=600&q=80&fit=crop" alt="Emergency kits" />
        </div>
        <div class="article-body">
          <div class="article-tag article-tag-product">Emergency Kits</div>
          <h3>Build the Right Emergency Kit for Your Home</h3>
          <p>Water storage, food supply, go-bag essentials, and special needs planning for every household type.</p>
          <span class="article-link">Read Guide →</span>
        </div>
      </a>

      <a href="/backup-power" class="article-card">
        <div class="article-img">
          <img src="https://images.unsplash.com/photo-1548438294-1ad5d5f4f063?w=600&q=80&fit=crop" alt="Backup power" />
        </div>
        <div class="article-body">
          <div class="article-tag article-tag-product">Backup Power</div>
          <h3>Home Backup Power — Every Option Explained</h3>
          <p>Power banks to whole-home standby systems. Every option compared by cost, power, and use case.</p>
          <span class="article-link">Read Guide →</span>
        </div>
      </a>

      <a href="/safe-rooms" class="article-card">
        <div class="article-img">
          <img src="https://images.unsplash.com/photo-1558618047-3c8c76ca7d13?w=600&q=80&fit=crop" alt="Safe rooms" />
        </div>
        <div class="article-body">
          <div class="article-tag article-tag-product">Safe Rooms</div>
          <h3>Safe Rooms & Storm Shelters — Complete Guide</h3>
          <p>FEMA ratings, above-ground vs underground, costs, grants, and installation guide.</p>
          <span class="article-link">Read Guide →</span>
        </div>
      </a>

      <a href="/insurance" class="article-card">
        <div class="article-img">
          <img src="https://images.unsplash.com/photo-1450101499163-c8848c66ca85?w=600&q=80&fit=crop" alt="Insurance" />
        </div>
        <div class="article-body">
          <div class="article-tag article-tag-product">Insurance</div>
          <h3>What Your Home Insurance Actually Covers</h3>
          <p>Coverage gaps, flood insurance, hurricane deductibles, and how to file a claim after a disaster.</p>
          <span class="article-link">Read Guide →</span>
        </div>
      </a>

    </div>

  </div>

</BaseLayout>

<style>
  .threat-hero { position: relative; height: 380px; display: flex; align-items: center; overflow: hidden; }
  .hero-img-wrap { position: absolute; inset: 0; z-index: 0; }
  .hero-img { width: 100%; height: 100%; object-fit: cover; object-position: center 30%; }
  .hero-overlay { position: absolute; inset: 0; background: linear-gradient(to right, rgba(13,35,56,0.92) 0%, rgba(13,35,56,0.65) 60%, rgba(13,35,56,0.3) 100%); }
  .hero-content { position: relative; z-index: 1; max-width: 640px; color: white; }
  .hero-label { font-size: 0.78rem; font-weight: 600; text-transform: uppercase; letter-spacing: 0.12em; color: #A8CEDF; margin-bottom: 16px; }
  .hero-content h1 { color: white; margin-bottom: 20px; }
  .hero-sub { font-size: 1.05rem; color: rgba(255,255,255,0.8); line-height: 1.7; max-width: 560px; }

  .articles-layout { padding: 56px 0 96px; }

  .section-heading { font-size: 1.3rem; color: var(--navy); margin: 48px 0 24px; padding-bottom: 12px; border-bottom: 2px solid var(--navy); }
  .section-heading:first-child { margin-top: 0; }

  .article-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 24px; margin-bottom: 16px; }

  .article-card { display: flex; flex-direction: column; background: white; border: 1px solid var(--border); border-radius: 10px; overflow: hidden; text-decoration: none; transition: transform 0.2s, box-shadow 0.2s; }
  .article-card:hover { transform: translateY(-4px); box-shadow: 0 8px 24px rgba(0,0,0,0.1); text-decoration: none; }

  .article-img { height: 180px; overflow: hidden; }
  .article-img img { width: 100%; height: 100%; object-fit: cover; transition: transform 0.3s; }
  .article-card:hover .article-img img { transform: scale(1.05); }

  .article-body { padding: 20px; flex: 1; display: flex; flex-direction: column; }
  .article-tag { display: inline-block; font-size: 0.68rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.08em; color: white; background: var(--sky); padding: 3px 8px; border-radius: 3px; margin-bottom: 10px; }
  .article-tag-product { background: var(--orange); }
  .article-body h3 { font-size: 0.95rem; color: var(--navy); margin: 0 0 8px; line-height: 1.4; }
  .article-body p { font-size: 0.82rem; color: var(--text-mid); line-height: 1.5; margin: 0 0 16px; flex: 1; }
  .article-link { font-size: 0.82rem; font-weight: 600; color: var(--sky); margin-top: auto; }
</style>