---
import BaseLayout from '../layouts/BaseLayout.astro'
import CardIcon from '../components/CardIcon.astro'
import { getEntry } from 'astro:content'

const homepage = await getEntry('homepage', 'index');
const { meta, hero, stats, threatsSection, productsSection, emailCapture } = homepage.data;

const headlineParts = hero.headline.split('|');
const linkLabel = (key: string) => key === 'flood' ? 'flooding' : key.replace('-', ' ');
---

<BaseLayout
  title={meta.title}
  description={meta.description}
>

  <!-- Hero -->
  <section class="hero">
    <div class="hero-img-wrap">
      <img
        src={hero.image}
        alt={hero.imageAlt}
        class="hero-img"
      />
      <div class="hero-overlay"></div>
    </div>
    <div class="container hero-content">
      <p class="hero-eyebrow">{hero.eyebrow}</p>
      <h1>{headlineParts[0]}<br/>{headlineParts[1]}</h1>
      <p class="hero-sub">{hero.subheading}</p>
      <div class="hero-ctas">
        <a href={hero.ctaPrimary.link} class="btn btn-primary">{hero.ctaPrimary.text}</a>
        <a href={hero.ctaSecondary.link} class="btn btn-secondary">{hero.ctaSecondary.text}</a>
      </div>
    </div>
  </section>

  <!-- Stats bar -->
  <div class="stats-bar">
    <div class="container stats-row">
      {stats.map((stat, i) => (
        <>
          {i > 0 && <div class="stat-div"></div>}
          <div class="stat">
            <strong>{stat.value}</strong>
            <span>{stat.label}</span>
          </div>
        </>
      ))}
    </div>
  </div>

  <!-- Threats section -->
  <section class="nav-section" id="threats">
    <div class="container">
      <div class="section-header">
        <h2>{threatsSection.heading}</h2>
        <p>{threatsSection.subheading}</p>
      </div>

      <div class="card-grid">
        {threatsSection.cards.map((card) => (
          <a href={card.link} class="nav-card">
            <div class="nav-card-img-wrap">
              <img src={card.image} alt={card.imageAlt} />
              <div class="nav-card-overlay"></div>
              <CardIcon iconKey={card.iconKey} />
            </div>
            <div class="nav-card-body">
              <h3>{card.title}</h3>
              <p>{card.description}</p>
              <span class="nav-card-link">View {linkLabel(card.iconKey)} guide →</span>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- Home Protection section -->
  <section class="nav-section nav-section-alt">
    <div class="container">
      <div class="section-header">
        <h2>{productsSection.heading}</h2>
        <p>{productsSection.subheading}</p>
      </div>

      <div class="card-grid card-grid-3">
        {productsSection.cards.map((card) => (
          <a href={card.link} class="nav-card nav-card-sm">
            <div class="nav-card-img-wrap">
              <img src={card.image} alt={card.imageAlt} />
              <div class="nav-card-overlay"></div>
              <CardIcon iconKey={card.iconKey} size="small" />
            </div>
            <div class="nav-card-body">
              <h3>{card.title}</h3>
              <p>{card.description}</p>
              <span class="nav-card-link">View guide →</span>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- Email capture -->
  <section class="email-section">
    <div class="container email-inner">
      <div class="email-text">
        <h2>{emailCapture.heading}</h2>
        <p>{emailCapture.subheading}</p>
      </div>
      <form class="email-form" name={emailCapture.formName} method="POST" data-netlify="true">
        <input type="hidden" name="form-name" value={emailCapture.formName} />
        <input type="email" name="email" placeholder="your@email.com" required />
        <button type="submit" class="btn btn-primary">{emailCapture.buttonText}</button>
      </form>
    </div>
  </section>

</BaseLayout>

<style>
  .hero { position: relative; height: 580px; display: flex; align-items: center; overflow: hidden; }
  .hero-img-wrap { position: absolute; inset: 0; z-index: 0; }
  .hero-img { width: 100%; height: 100%; object-fit: cover; object-position: center; }
  .hero-overlay { position: absolute; inset: 0; background: linear-gradient(to right, rgba(13,35,56,0.92) 0%, rgba(13,35,56,0.7) 50%, rgba(13,35,56,0.3) 100%); }
  .hero-content { position: relative; z-index: 1; max-width: 640px; color: white; }
  .hero-eyebrow { font-size: 0.78rem; font-weight: 600; text-transform: uppercase; letter-spacing: 0.12em; color: #A8CEDF; margin-bottom: 16px; }
  .hero-content h1 { color: white; margin-bottom: 20px; font-size: clamp(2rem, 4vw, 3rem); }
  .hero-sub { font-size: 1.1rem; color: rgba(255,255,255,0.8); line-height: 1.7; margin-bottom: 32px; }
  .hero-ctas { display: flex; gap: 12px; flex-wrap: wrap; }

  .stats-bar { background: var(--navy); border-bottom: 3px solid var(--orange); padding: 20px 0; }
  .stats-row { display: flex; align-items: center; }
  .stat { flex: 1; padding: 0 28px; }
  .stat:first-child { padding-left: 0; }
  .stat strong { display: block; font-size: 1.1rem; color: var(--orange); font-weight: 700; }
  .stat span { font-size: 0.78rem; color: rgba(255,255,255,0.65); line-height: 1.4; }
  .stat-div { width: 1px; height: 40px; background: rgba(255,255,255,0.12); flex-shrink: 0; }

  .nav-section { padding: 72px 0; }
  .nav-section-alt { background: var(--off-white); }
  .section-header { margin-bottom: 40px; }
  .section-header h2 { color: var(--navy); margin-bottom: 8px; }
  .section-header p { color: var(--text-mid); font-size: 1rem; }

  .card-grid { display: grid; grid-template-columns: repeat(5, 1fr); gap: 20px; }
  .card-grid-3 { grid-template-columns: repeat(3, 1fr); }

  .nav-card { display: flex; flex-direction: column; border-radius: 10px; overflow: hidden; border: 1px solid var(--border); background: white; text-decoration: none; transition: transform 0.2s, box-shadow 0.2s; color: var(--text); }
  .nav-card:hover { transform: translateY(-4px); box-shadow: 0 12px 32px rgba(0,0,0,0.12); text-decoration: none; }

  .nav-card-img-wrap { position: relative; height: 160px; overflow: hidden; flex-shrink: 0; }
  .nav-card-sm .nav-card-img-wrap { height: 130px; }
  .nav-card-img-wrap img { width: 100%; height: 100%; object-fit: cover; transition: transform 0.3s; }
  .nav-card:hover .nav-card-img-wrap img { transform: scale(1.05); }
  .nav-card-overlay { position: absolute; inset: 0; background: linear-gradient(to top, rgba(13,35,56,0.75) 0%, rgba(13,35,56,0.2) 100%); }

  .nav-card-body { padding: 16px; display: flex; flex-direction: column; gap: 6px; flex: 1; }
  .nav-card-body h3 { font-size: 1rem; color: var(--navy); margin: 0; }
  .nav-card-sm .nav-card-body h3 { font-size: 0.95rem; }
  .nav-card-body p { font-size: 0.82rem; color: var(--text-mid); line-height: 1.5; margin: 0; flex: 1; }
  .nav-card-link { font-size: 0.8rem; font-weight: 600; color: var(--sky); margin-top: 4px; }

  .email-section { background: var(--navy); padding: 60px 0; }
  .email-inner { display: flex; align-items: center; gap: 48px; flex-wrap: wrap; }
  .email-text { flex: 1; min-width: 280px; }
  .email-text h2 { color: white; margin-bottom: 8px; font-size: 1.5rem; }
  .email-text p { color: rgba(255,255,255,0.7); font-size: 0.9rem; }
  .email-form { display: flex; gap: 10px; flex-wrap: wrap; }
  .email-form input { padding: 11px 16px; border-radius: 4px; border: none; font-size: 0.9rem; min-width: 260px; font-family: var(--font-sans); }
</style>
