---
import { DISCLOSURE } from '../lib/affiliates.js'
const { title, description } = Astro.props
const currentPath = Astro.url.pathname
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content={description} />
  <title>{title} | Weather Safe Home</title>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Source+Serif+4:wght@400;600&display=swap" rel="stylesheet" />
</head>

<body>

  <header class="site-header">
    <div class="container">
      <a href="/" class="logo">
        <span class="logo-weather">Weather</span><span class="logo-safe">Safe</span><span class="logo-home">Home</span>
      </a>
      <nav class="main-nav">
        <a href="/free-checklists">Free Checklists</a>

        <div class="nav-dropdown">
          <span class="nav-parent">Threats ▾</span>
          <div class="nav-dropdown-menu">
            <a href="/hurricanes">Hurricanes</a>
            <a href="/tornadoes">Tornadoes</a>
            <a href="/winter-storms">Winter Storms</a>
            <a href="/flooding">Flash Flooding</a>
            <a href="/wildfires">Wildfires</a>
          </div>
        </div>

        <div class="nav-dropdown">
          <span class="nav-parent">Home Protection ▾</span>
          <div class="nav-dropdown-menu">
            <a href="/generators">Generators</a>
            <a href="/insurance">Insurance</a>
            <a href="/emergency-kits">Emergency Kits</a>
            <a href="/flood-protection-products">Flood Protection Products</a>
            <a href="/safe-rooms">Safe Rooms</a>
            <a href="/backup-power">Backup Power</a>
            <a href="/smart-home-devices">Smart Home Devices</a>
          </div>
        </div>

        <a href="/articles">Articles</a>
        <a href="/about">About</a>
      </nav>
    </div>
  </header>

  <div class="disclosure-bar">
    <div class="container">
      {DISCLOSURE}
    </div>
  </div>

  <main>
    <slot />
  </main>

  <footer class="site-footer">
    <div class="container footer-inner">
      <div class="footer-brand">
        <div class="footer-logo">WeatherSafeHome.org</div>
        <p>Helping homeowners prepare for and protect against weather perils.</p>
        <p class="footer-disclosure">{DISCLOSURE}</p>
      </div>
      <div class="footer-links">
        <div>
          <h4>Threats</h4>
          <a href="/hurricanes">Hurricanes</a>
          <a href="/flooding">Flooding</a>
          <a href="/wildfires">Wildfires</a>
          <a href="/winter-storms">Winter Storms</a>
          <a href="/tornadoes">Tornadoes</a>
        </div>
        <div>
          <h4>Home Protection</h4>
          <a href="/generators">Generators</a>
          <a href="/insurance">Insurance</a>
          <a href="/emergency-kits">Emergency Kits</a>
          <a href="/flood-protection-products">Flood Protection</a>
          <a href="/safe-rooms">Safe Rooms</a>
          <a href="/backup-power">Backup Power</a>
        </div>
        <div>
          <h4>About</h4>
          <a href="/about">About Us</a>
          <a href="/articles">Articles</a>
          <a href="/free-checklists">Free Checklists</a>
          <a href="/contact">Contact</a>
          <a href="/privacy-policy">Privacy Policy</a>
          <a href="/terms">Terms of Service</a>
        </div>
      </div>
    </div>
    <div class="footer-bottom">
      <div class="container">
        © {new Date().getFullYear()} WeatherSafeHome.org · All rights reserved
      </div>
    </div>
  </footer>

</body>
</html>

<style is:global>
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  :root {
    --navy:       #1B3A52;
    --navy-light: #2C5F82;
    --sky:        #2E7CB8;
    --sky-light:  #EBF4FB;
    --orange:     #D4691E;
    --orange-bg:  #FDF3EA;
    --white:      #ffffff;
    --off-white:  #F7F9FB;
    --border:     #DDE6EE;
    --text:       #1A2733;
    --text-mid:   #4A5C6A;
    --text-light: #7A8C99;
    --font-sans:  'Inter', system-ui, sans-serif;
    --font-serif: 'Source Serif 4', Georgia, serif;
  }

  body {
    font-family: var(--font-sans);
    color: var(--text);
    background: var(--white);
    line-height: 1.6;
    font-size: 16px;
  }

  .container {
    max-width: 1160px;
    margin: 0 auto;
    padding: 0 32px;
  }

  a { color: var(--sky); text-decoration: none; }
  a:hover { text-decoration: underline; }

  img { max-width: 100%; height: auto; }

  /* ── Header ── */
  .site-header {
    background: var(--navy);
    position: sticky;
    top: 0;
    z-index: 100;
    border-bottom: 3px solid var(--orange);
  }

  .site-header .container {
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 68px;
  }

  .logo { font-size: 1.25rem; font-weight: 700; text-decoration: none; letter-spacing: -0.01em; }
  .logo-weather { color: #fff; }
  .logo-safe    { color: var(--orange); }
  .logo-home    { color: #A8CEDF; }

  .main-nav { display: flex; gap: 2px; align-items: center; }

  .main-nav > a {
    color: rgba(255,255,255,0.85);
    font-size: 0.88rem;
    font-weight: 500;
    padding: 8px 12px;
    border-radius: 4px;
    transition: all 0.15s;
    text-decoration: none;
  }

  .main-nav > a:hover { color: #fff; background: rgba(255,255,255,0.1); }

  .nav-dropdown { position: relative; }

  .nav-parent {
    color: rgba(255,255,255,0.85);
    font-size: 0.88rem;
    font-weight: 500;
    padding: 8px 12px;
    border-radius: 4px;
    cursor: pointer;
    transition: all 0.15s;
    white-space: nowrap;
    display: block;
    user-select: none;
  }

  .nav-dropdown:hover .nav-parent { color: #fff; background: rgba(255,255,255,0.1); }

  .nav-dropdown-menu {
    display: none;
    position: absolute;
    top: calc(100% + 4px);
    left: 0;
    background: #fff;
    border: 1px solid var(--border);
    border-radius: 6px;
    padding: 6px 0;
    min-width: 220px;
    box-shadow: 0 8px 32px rgba(0,0,0,0.12);
    z-index: 200;
  }

  .nav-dropdown:hover .nav-dropdown-menu {
  display: block;
}

.nav-dropdown-menu {
  padding-top: 8px;
  margin-top: -8px;
 }

  .nav-dropdown-menu a {
    display: block;
    color: var(--text);
    font-size: 0.88rem;
    padding: 9px 16px;
    text-decoration: none;
    transition: background 0.1s;
    border-bottom: 1px solid #f0f0f0;
  }

  .nav-dropdown-menu a:last-child { border-bottom: none; }
  .nav-dropdown-menu a:hover { background: var(--sky-light); color: var(--sky); }

  /* ── Disclosure bar ── */
  .disclosure-bar {
    background: var(--off-white);
    border-bottom: 1px solid var(--border);
    font-size: 0.72rem;
    color: var(--text-light);
    padding: 7px 0;
  }

  /* ── Footer ── */
  .site-footer {
    background: var(--navy);
    color: rgba(255,255,255,0.7);
    margin-top: 100px;
  }

  .footer-inner {
    display: grid;
    grid-template-columns: 2fr 3fr;
    gap: 64px;
    padding: 64px 32px 48px;
  }

  .footer-brand p {
    font-size: 0.85rem;
    line-height: 1.6;
    margin-top: 12px;
    color: rgba(255,255,255,0.55);
  }

  .footer-logo {
    font-size: 1.15rem;
    font-weight: 700;
    color: white;
  }

  .footer-disclosure {
    margin-top: 16px !important;
    font-size: 0.72rem !important;
    border-top: 1px solid rgba(255,255,255,0.1);
    padding-top: 16px;
  }

  .footer-links {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 32px;
  }

  .footer-links h4 {
    font-size: 0.72rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--orange);
    margin-bottom: 14px;
    font-weight: 600;
  }

  .footer-links a {
    display: block;
    color: rgba(255,255,255,0.6);
    font-size: 0.85rem;
    margin-bottom: 8px;
    text-decoration: none;
    transition: color 0.15s;
  }

  .footer-links a:hover { color: white; }

  .footer-bottom {
    border-top: 1px solid rgba(255,255,255,0.08);
    padding: 16px 32px;
    font-size: 0.78rem;
    color: rgba(255,255,255,0.35);
  }

  /* ── Utility ── */
  .btn {
    display: inline-block;
    padding: 11px 22px;
    border-radius: 4px;
    font-weight: 600;
    font-size: 0.9rem;
    text-decoration: none;
    transition: all 0.15s;
    cursor: pointer;
    border: none;
    font-family: var(--font-sans);
  }

  .btn-primary { background: var(--orange); color: white; }
  .btn-primary:hover { background: #b85a18; text-decoration: none; }

  .btn-secondary {
    background: transparent;
    color: white;
    border: 1.5px solid rgba(255,255,255,0.45);
  }
  .btn-secondary:hover { border-color: white; text-decoration: none; }

  .btn-outline {
    background: transparent;
    color: var(--sky);
    border: 1.5px solid var(--sky);
  }
  .btn-outline:hover { background: var(--sky-light); text-decoration: none; }

  h1 { font-size: clamp(1.75rem, 3.5vw, 2.6rem); line-height: 1.2; font-weight: 700; }
  h2 { font-size: clamp(1.3rem, 2.5vw, 1.75rem); line-height: 1.3; font-weight: 700; }
  h3 { font-size: 1.1rem; line-height: 1.4; font-weight: 600; }
</style>