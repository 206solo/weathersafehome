---
// BaseLayout.astro
// Every page on the site uses this layout.
// It handles the <head>, navigation, footer, and disclosure.
import { DISCLOSURE } from '../lib/affiliates.js'

const { title, description } = Astro.props
const currentPath = Astro.url.pathname
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content={description} />
  <title>{title} | Weather Safe Home</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet" />
</head>

<body>

  <!-- ── Navigation ── -->
  <header class="site-header">
    <div class="container">
      <a href="/" class="logo">
        <span class="logo-weather">Weather</span><span class="logo-safe">Safe</span><span class="logo-home">Home</span>
      </a>
      <nav class="main-nav">
        <a href="/hurricanes" class:list={[{active: currentPath.startsWith('/hurricanes')}]}>Hurricanes</a>
        <a href="/flooding" class:list={[{active: currentPath.startsWith('/flooding')}]}>Flooding</a>
        <a href="/wildfires" class:list={[{active: currentPath.startsWith('/wildfires')}]}>Wildfires</a>
        <a href="/winter-storms" class:list={[{active: currentPath.startsWith('/winter-storms')}]}>Winter Storms</a>
        <a href="/tornadoes" class:list={[{active: currentPath.startsWith('/tornadoes')}]}>Tornadoes</a>
        <a href="/generators" class:list={[{active: currentPath.startsWith('/generators')}]}>Generators</a>
        <a href="/articles" class:list={[{active: currentPath.startsWith('/articles')}]}>Articles</a>
      </nav>
    </div>
  </header>

  <!-- ── Affiliate disclosure bar (shows on all pages) ── -->
  <div class="disclosure-bar">
    <div class="container">
      🔗 {DISCLOSURE}
    </div>
  </div>

  <!-- ── Page content ── -->
  <main>
    <slot />
  </main>

  <!-- ── Footer ── -->
  <footer class="site-footer">
    <div class="container footer-grid">
      <div>
        <div class="footer-logo">WeatherSafeHome.org</div>
        <p>Helping homeowners prepare for and protect against weather perils.</p>
      </div>
      <div>
        <h4>Storm Types</h4>
        <a href="/hurricanes">Hurricanes</a>
        <a href="/flooding">Flooding</a>
        <a href="/wildfires">Wildfires</a>
        <a href="/winter-storms">Winter Storms</a>
        <a href="/tornadoes">Tornadoes</a>
      </div>
      <div>
        <h4>Resources</h4>
        <a href="/generators">Generators</a>
        <a href="/insurance">Insurance</a>
        <a href="/articles">All Articles</a>
      </div>
      <div>
        <h4>About</h4>
        <a href="/about">About Us</a>
        <a href="/contact">Contact</a>
        <a href="/privacy-policy">Privacy Policy</a>
        <a href="/terms">Terms of Service</a>
      </div>
    </div>
    <div class="footer-bottom container">
      <p>© {new Date().getFullYear()} WeatherSafeHome.org · All rights reserved</p>
      <p class="footer-disclosure">{DISCLOSURE}</p>
    </div>
  </footer>

</body>
</html>

<style is:global>
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  :root {
    --navy:      #0D2B45;
    --steel:     #1B4F72;
    --sky:       #2E86C1;
    --light-sky: #AED6F1;
    --pale-blue: #EBF5FB;
    --orange:    #E67E22;
    --amber:     #F39C12;
    --white:     #ffffff;
    --off-white: #F8FBFE;
    --dark:      #1a1a2e;
    --mid-gray:  #5D6D7E;
    --light-gray:#f0f4f8;
    --font:      'Inter', system-ui, sans-serif;
  }

  body {
    font-family: var(--font);
    color: var(--dark);
    background: var(--white);
    line-height: 1.6;
  }

  .container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 24px;
  }

  a { color: var(--sky); text-decoration: none; }
  a:hover { text-decoration: underline; }

  /* ── Header ── */
  .site-header {
    background: var(--navy);
    padding: 0;
    position: sticky;
    top: 0;
    z-index: 100;
    box-shadow: 0 2px 12px rgba(0,0,0,0.3);
  }

  .site-header .container {
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 64px;
  }

  .logo {
    font-size: 1.3rem;
    font-weight: 700;
    text-decoration: none;
  }
  .logo-weather { color: var(--white); }
  .logo-safe    { color: var(--orange); }
  .logo-home    { color: var(--light-sky); }

  .main-nav {
    display: flex;
    gap: 4px;
    align-items: center;
  }

  .main-nav a {
    color: rgba(255,255,255,0.8);
    font-size: 0.85rem;
    font-weight: 500;
    padding: 6px 10px;
    border-radius: 4px;
    transition: all 0.15s;
    text-decoration: none;
  }

  .main-nav a:hover,
  .main-nav a.active {
    color: var(--white);
    background: rgba(255,255,255,0.12);
  }

  /* ── Disclosure bar ── */
  .disclosure-bar {
    background: var(--pale-blue);
    border-bottom: 1px solid var(--light-sky);
    font-size: 0.75rem;
    color: var(--mid-gray);
    padding: 6px 0;
  }

  /* ── Footer ── */
  .site-footer {
    background: var(--navy);
    color: rgba(255,255,255,0.7);
    margin-top: 80px;
    padding: 60px 0 0;
  }

  .footer-grid {
    display: grid;
    grid-template-columns: 2fr 1fr 1fr 1fr;
    gap: 40px;
    padding-bottom: 40px;
  }

  .footer-logo {
    font-size: 1.2rem;
    font-weight: 700;
    color: white;
    margin-bottom: 12px;
  }

  .footer-grid h4 {
    color: var(--orange);
    font-size: 0.8rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    margin-bottom: 12px;
  }

  .footer-grid a {
    display: block;
    color: rgba(255,255,255,0.65);
    font-size: 0.85rem;
    margin-bottom: 6px;
    text-decoration: none;
  }

  .footer-grid a:hover { color: white; }

  .footer-bottom {
    border-top: 1px solid rgba(255,255,255,0.1);
    padding: 20px 24px;
    font-size: 0.75rem;
    color: rgba(255,255,255,0.4);
  }

  .footer-disclosure { margin-top: 6px; }

  /* ── Utility classes used across pages ── */
  .btn {
    display: inline-block;
    padding: 12px 24px;
    border-radius: 6px;
    font-weight: 600;
    font-size: 0.95rem;
    text-decoration: none;
    transition: all 0.15s;
    cursor: pointer;
  }

  .btn-primary {
    background: var(--orange);
    color: white;
  }
  .btn-primary:hover {
    background: var(--amber);
    text-decoration: none;
  }

  .btn-secondary {
    background: transparent;
    color: white;
    border: 2px solid rgba(255,255,255,0.5);
  }
  .btn-secondary:hover {
    border-color: white;
    text-decoration: none;
  }

  h1 { font-size: clamp(1.8rem, 4vw, 2.8rem); line-height: 1.2; }
  h2 { font-size: clamp(1.4rem, 3vw, 2rem); line-height: 1.3; }
  h3 { font-size: 1.2rem; line-height: 1.4; }
</style>