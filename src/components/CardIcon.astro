---
interface Props {
  iconKey: string;
  size?: 'default' | 'small';
}
const { iconKey, size = 'default' } = Astro.props;
const isSmall = size === 'small';
---

<div class={`nav-card-icon ${isSmall ? 'nav-card-icon-sm' : ''}`}>
  {iconKey === 'hurricane' && (
    <svg viewBox="0 0 48 48" fill="none" xmlns="http://www.w3.org/2000/svg">
      <path d="M24 8C24 8 32 16 32 24C32 28.4 29.6 32.4 24 34C18.4 32.4 16 28.4 16 24C16 16 24 8 24 8Z" stroke="white" stroke-width="2" stroke-linejoin="round"/>
      <path d="M12 20C16 18 20 20 24 20C28 20 32 18 36 20" stroke="white" stroke-width="2" stroke-linecap="round"/>
      <path d="M10 28C14 26 18 28 24 28C30 28 34 26 38 28" stroke="white" stroke-width="2" stroke-linecap="round"/>
      <circle cx="24" cy="24" r="3" fill="white"/>
    </svg>
  )}
  {iconKey === 'flood' && (
    <svg viewBox="0 0 48 48" fill="none" xmlns="http://www.w3.org/2000/svg">
      <path d="M8 30C12 26 16 34 20 30C24 26 28 34 32 30C36 26 40 34 40 30" stroke="white" stroke-width="2.5" stroke-linecap="round"/>
      <path d="M8 38C12 34 16 42 20 38C24 34 28 42 32 38C36 34 40 42 40 38" stroke="white" stroke-width="2.5" stroke-linecap="round"/>
      <path d="M24 8V22M18 14L24 8L30 14" stroke="white" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/>
    </svg>
  )}
  {iconKey === 'wildfire' && (
    <svg viewBox="0 0 48 48" fill="none" xmlns="http://www.w3.org/2000/svg">
      <path d="M24 40C24 40 12 32 12 22C12 16 16 12 20 10C18 14 20 18 24 20C22 16 24 10 30 8C28 14 32 16 34 22C36 28 30 36 24 40Z" stroke="white" stroke-width="2" stroke-linejoin="round" fill="rgba(255,255,255,0.15)"/>
    </svg>
  )}
  {iconKey === 'winter-storm' && (
    <svg viewBox="0 0 48 48" fill="none" xmlns="http://www.w3.org/2000/svg">
      <path d="M24 8V40M8 24H40M13 13L35 35M35 13L13 35" stroke="white" stroke-width="2.5" stroke-linecap="round"/>
      <circle cx="24" cy="24" r="4" fill="white"/>
    </svg>
  )}
  {iconKey === 'tornado' && (
    <svg viewBox="0 0 48 48" fill="none" xmlns="http://www.w3.org/2000/svg">
      <path d="M10 14H38" stroke="white" stroke-width="2.5" stroke-linecap="round"/>
      <path d="M14 22H34" stroke="white" stroke-width="2.5" stroke-linecap="round"/>
      <path d="M18 30H30" stroke="white" stroke-width="2.5" stroke-linecap="round"/>
      <path d="M21 38H27" stroke="white" stroke-width="2.5" stroke-linecap="round"/>
    </svg>
  )}
  {iconKey === 'generator' && (
    <svg viewBox="0 0 40 40" fill="none" xmlns="http://www.w3.org/2000/svg">
      <path d="M20 6L10 22H20L18 34L30 18H20L20 6Z" stroke="white" stroke-width="2" stroke-linejoin="round" fill="rgba(255,255,255,0.2)"/>
    </svg>
  )}
  {iconKey === 'insurance' && (
    <svg viewBox="0 0 40 40" fill="none" xmlns="http://www.w3.org/2000/svg">
      <path d="M20 6L8 11V20C8 27 14 33 20 35C26 33 32 27 32 20V11L20 6Z" stroke="white" stroke-width="2" stroke-linejoin="round" fill="rgba(255,255,255,0.15)"/>
      <path d="M14 20L18 24L26 16" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
    </svg>
  )}
  {iconKey === 'emergency-kit' && (
    <svg viewBox="0 0 40 40" fill="none" xmlns="http://www.w3.org/2000/svg">
      <rect x="8" y="14" width="24" height="18" rx="2" stroke="white" stroke-width="2"/>
      <path d="M14 14V11C14 9.3 15.3 8 17 8H23C24.7 8 26 9.3 26 11V14" stroke="white" stroke-width="2"/>
      <path d="M20 19V27M16 23H24" stroke="white" stroke-width="2" stroke-linecap="round"/>
    </svg>
  )}
  {iconKey === 'flood-protection' && (
    <svg viewBox="0 0 40 40" fill="none" xmlns="http://www.w3.org/2000/svg">
      <path d="M8 26C11 22 14 30 17 26C20 22 23 30 26 26C29 22 32 30 32 26" stroke="white" stroke-width="2" stroke-linecap="round"/>
      <rect x="10" y="12" width="20" height="12" rx="1" stroke="white" stroke-width="2" fill="rgba(255,255,255,0.1)"/>
    </svg>
  )}
  {iconKey === 'safe-room' && (
    <svg viewBox="0 0 40 40" fill="none" xmlns="http://www.w3.org/2000/svg">
      <rect x="8" y="8" width="24" height="24" rx="2" stroke="white" stroke-width="2" fill="rgba(255,255,255,0.1)"/>
      <circle cx="20" cy="20" r="4" stroke="white" stroke-width="2"/>
    </svg>
  )}
  {iconKey === 'backup-power' && (
    <svg viewBox="0 0 40 40" fill="none" xmlns="http://www.w3.org/2000/svg">
      <rect x="10" y="12" width="20" height="18" rx="2" stroke="white" stroke-width="2" fill="rgba(255,255,255,0.1)"/>
      <path d="M15 12V9M25 12V9" stroke="white" stroke-width="2" stroke-linecap="round"/>
      <path d="M20 17V23M17 20H23" stroke="white" stroke-width="2" stroke-linecap="round"/>
    </svg>
  )}
</div>

<style>
  .nav-card-icon { position: absolute; top: 12px; left: 12px; width: 44px; height: 44px; background: rgba(13,35,56,0.6); border-radius: 8px; display: flex; align-items: center; justify-content: center; backdrop-filter: blur(4px); }
  .nav-card-icon svg { width: 28px; height: 28px; }
  .nav-card-icon-sm { width: 36px; height: 36px; top: 10px; left: 10px; }
  .nav-card-icon-sm svg { width: 22px; height: 22px; }
</style>
