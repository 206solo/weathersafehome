---
const { name, asin, url, price, store = 'amazon', img, desc, badge } = Astro.props
import { amazonLink } from '../lib/affiliates.js'

let href = url
if (store === 'amazon' && asin) href = amazonLink(asin)
---

<div class="product-card">
  {badge && <div class="badge">{badge}</div>}
  <h4>{name}</h4>
  {desc && <p>{desc}</p>}
  <div class="card-footer">
    <span class="price">{price}</span>
    <a href={href} target="_blank" rel="nofollow sponsored noopener" class="buy-btn">
      View on {store === 'amazon' ? 'Amazon' : store === 'homedepot' ? 'Home Depot' : 'Lowe\'s'} →
    </a>
  </div>
</div>

<style>
  .product-card {
    background: white;
    border: 1px solid var(--border);
    border-radius: 8px;
    padding: 20px;
    display: flex;
    flex-direction: column;
    gap: 10px;
    position: relative;
  }

  .badge {
    display: inline-block;
    background: var(--orange);
    color: white;
    font-size: 0.65rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    padding: 3px 8px;
    border-radius: 4px;
    align-self: flex-start;
    margin-bottom: 2px;
  }

  h4 {
    font-size: 0.95rem;
    font-weight: 600;
    color: var(--navy);
    margin: 0;
    line-height: 1.4;
  }

  p {
    font-size: 0.82rem;
    color: var(--text-mid);
    line-height: 1.5;
    margin: 0;
    flex: 1;
  }

  .card-footer {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 10px;
    margin-top: 4px;
    flex-wrap: wrap;
  }

  .price {
    font-size: 1.1rem;
    font-weight: 700;
    color: var(--navy);
  }

  .buy-btn {
    background: var(--orange);
    color: white;
    padding: 8px 14px;
    border-radius: 5px;
    font-size: 0.82rem;
    font-weight: 600;
    text-decoration: none;
    white-space: nowrap;
    transition: background 0.15s;
  }

  .buy-btn:hover {
    background: #b85a18;
    text-decoration: none;
  }
</style>