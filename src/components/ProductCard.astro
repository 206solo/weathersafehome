---
// ProductCard.astro
// Reusable affiliate product card.
// Usage: <ProductCard name="Wayne CDU980E" asin="B00123456" price="$189" 
//          store="amazon" img="url" desc="Best budget sump pump" />

import { amazonLink, homedepotLink, lowesLink } from '../lib/affiliates.js'

const { name, asin, url, price, store = 'amazon', img, desc, badge } = Astro.props

function getLink() {
  if (store === 'amazon' && asin) return amazonLink(asin)
  if (store === 'homedepot' && url) return homedepotLink(url)
  if (store === 'lowes' && url) return lowesLink(url)
  return url || '#'
}

const storeName = {
  amazon: 'Amazon',
  homedepot: 'Home Depot',
  lowes: "Lowe's",
  acehardware: 'Ace Hardware',
}[store] || store
---

<div class="product-card">
  {badge && <div class="product-badge">{badge}</div>}
  {img && <img src={img} alt={name} class="product-img" />}
  <div class="product-body">
    <h3 class="product-name">{name}</h3>
    {desc && <p class="product-desc">{desc}</p>}
    <div class="product-footer">
      {price && <span class="product-price">{price}</span>}
      <a 
        href={getLink()} 
        target="_blank" 
        rel="nofollow sponsored noopener"
        class="product-btn"
      >
        View on {storeName} →
      </a>
    </div>
  </div>
</div>

<style>
  .product-card {
    border: 1px solid #e2eaf2;
    border-radius: 10px;
    overflow: hidden;
    background: white;
    box-shadow: 0 2px 8px rgba(0,0,0,0.06);
    transition: box-shadow 0.2s;
    position: relative;
  }

  .product-card:hover {
    box-shadow: 0 6px 20px rgba(0,0,0,0.12);
  }

  .product-badge {
    position: absolute;
    top: 12px;
    left: 12px;
    background: var(--orange);
    color: white;
    font-size: 0.7rem;
    font-weight: 700;
    padding: 3px 8px;
    border-radius: 4px;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .product-img {
    width: 100%;
    height: 180px;
    object-fit: contain;
    background: #f8fbfe;
    padding: 16px;
  }

  .product-body {
    padding: 16px;
  }

  .product-name {
    font-size: 1rem;
    font-weight: 600;
    margin-bottom: 8px;
    color: var(--dark);
  }

  .product-desc {
    font-size: 0.85rem;
    color: var(--mid-gray);
    margin-bottom: 16px;
    line-height: 1.5;
  }

  .product-footer {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 12px;
  }

  .product-price {
    font-size: 1.1rem;
    font-weight: 700;
    color: var(--steel);
  }

  .product-btn {
    display: inline-block;
    background: var(--orange);
    color: white;
    padding: 8px 14px;
    border-radius: 5px;
    font-size: 0.82rem;
    font-weight: 600;
    text-decoration: none;
    white-space: nowrap;
    transition: background 0.15s;
  }

  .product-btn:hover {
    background: var(--amber);
    text-decoration: none;
  }
</style>